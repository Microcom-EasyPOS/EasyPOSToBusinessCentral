						"url": {
							"raw": "{{baseUrl}}/{{tenant}}/{{environment}}/ODataV4/Company('{{company}}')/{{prefix}}Item",
							"host": ["{{baseUrl}}"],
							"path": ["{{tenant}}", "{{environment}}", "ODataV4", "Company('{{company}}')", "{{prefix}}Item"]
						},
						"description": "Henter alle varer fra Business Central."
					},
					"response": []
				}
			]
		},
		{
			"name": "VariantId (Varianter)",
			"description": "Vare-varianter",
