						"url": {
							"raw": "{{baseUrl}}/{{tenant}}/{{environment}}/ODataV4/Company('{{company}}')/{{prefix}}VariantId",
							"host": ["{{baseUrl}}"],
							"path": ["{{tenant}}", "{{environment}}", "ODataV4", "Company('{{company}}')", "{{prefix}}VariantId"]
