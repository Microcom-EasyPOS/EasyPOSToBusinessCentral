			"description": "Item access data",
			"item": [
				{
					"name": "GET ItemAccess",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/{{tenant}}/{{environment}}/ODataV4/Company('{{company}}')/{{prefix}}ItemAccess",
							"host": ["{{baseUrl}}"],
							"path": ["{{tenant}}", "{{environment}}", "ODataV4", "Company('{{company}}')", "{{prefix}}ItemAccess"]
						},
						"description": "Henter item access data fra Business Central."
					},
					"response": []
